# 应用运行环境：local / staging / production。
APP_ENV=local
# 日志级别：DEBUG / INFO / WARNING / ERROR。
LOG_LEVEL=INFO
# 本地或容器内监听地址。
HOST=0.0.0.0
# 本地或容器内监听端口。
PORT=8000
# Nginx 反向代理对外端口；self-host 模式下公网只应暴露这个端口。
REVIEW_PROXY_PORT=18080
# Nginx 反向代理访问 token；生产环境必须改为强随机值。
REVIEW_PROXY_TOKEN=

# 数据库连接地址；本地默认使用 SQLite，测试/生产建议使用 PostgreSQL。
DATABASE_URL=sqlite+aiosqlite:///./review_orchestrator.db
# docker-compose.self_host.yaml 使用的 PostgreSQL 数据库名。
POSTGRES_DB=review_orchestrator
# docker-compose.self_host.yaml 使用的 PostgreSQL 用户名。
POSTGRES_USER=review
# docker-compose.self_host.yaml 使用的 PostgreSQL 密码；生产环境必须改为强密码。
POSTGRES_PASSWORD=review

# GitHub webhook secret；生产环境必须配置，留空时会跳过签名校验，仅适合本地开发。
GITHUB_WEBHOOK_SECRET=
# GitHub App ID；使用 GitHub App 集成时填写。
GITHUB_APP_ID=
# GitHub App 私钥文件路径；不要把私钥提交到仓库。
GITHUB_PRIVATE_KEY_PATH=
# GitHub API 地址；GitHub Enterprise 可替换为企业实例 API 地址。
GITHUB_API_BASE_URL=https://api.github.com
# GitHub 安装访问 token；workspace checkout 可通过 auth.token_ref 引用该变量名。
GITHUB_INSTALLATION_TOKEN=
# Review bot 登录名；PR 评论中 @该账号 时会被识别为 agent 触发上下文。
REVIEW_BOT_LOGIN=review-agent

# GitLab webhook shared token；生产环境必须配置，留空时会跳过 token 校验。
GITLAB_WEBHOOK_SECRET=
# GitLab API 地址；自托管 GitLab 可替换为实例 API 地址。
GITLAB_API_BASE_URL=https://gitlab.com/api/v4
# GitLab bot/project/group token，用于 MR changes 查询和 summary note 发布。
GITLAB_API_TOKEN=

# OpenHands App Server 地址。
OPENHANDS_BASE_URL=http://localhost:3000
# docker-compose.self_host.yaml 使用的 OpenHands 镜像。
OPENHANDS_IMAGE=docker.all-hands.dev/all-hands-ai/openhands:latest
# OpenHands 前端本机访问端口；仅监听 127.0.0.1。
OPENHANDS_FRONTEND_PORT=3000
# 旧版 OpenHands 端口变量；未设置 OPENHANDS_FRONTEND_PORT 时作为兼容回退。
OPENHANDS_PORT=3000
# Sandbox 回连 OpenHands App Server 的宿主机地址；通常跟 OPENHANDS_FRONTEND_PORT 一致。
OH_WEB_URL=http://host.docker.internal:3000
# Sandbox 回调端口；self-host compose 通过 Nginx 的 /api/v1/webhooks 转发到 OpenHands。
SANDBOX_HOST_PORT=18080
# Docker Desktop/WSL 的 host-gateway 可能不能回连已发布端口；sandbox 使用 bridge gateway。
OH_SANDBOX_EXTRA_HOSTS={"host.docker.internal":"172.17.0.1"}
# OpenHands API token；如果 OpenHands 未开启鉴权可留空。
OPENHANDS_API_TOKEN=
# OpenHands/LiteLLM 模型配置；例如 openai/gpt-4.1。
LLM_MODEL=
# OpenHands/LiteLLM API key；不要提交真实 key。
LLM_API_KEY=
# OpenAI 兼容服务地址；使用默认 provider 时可留空。
LLM_BASE_URL=
# OpenHands sandbox runtime 镜像。
SANDBOX_RUNTIME_CONTAINER_IMAGE=docker.all-hands.dev/all-hands-ai/runtime:latest
# 是否记录 OpenHands 全量事件日志。
OPENHANDS_LOG_ALL_EVENTS=false
# 默认 Review skill 名称。
OPENHANDS_REVIEW_SKILL=code-review
# 默认 Review profile 名称。
OPENHANDS_REVIEW_PROFILE=default
# 调用 OpenHands API 的超时时间，单位秒。
OPENHANDS_TIMEOUT_SECONDS=30

# PR workspace 存储根目录；生产环境建议挂载到持久化磁盘。
WORKSPACE_ROOT=./.workspaces
# Git bare mirror 缓存目录，用于加速重复 checkout。
GIT_CACHE_ROOT=./.git-cache
# review run 硬超时时间，单位秒。
REVIEW_RUN_TIMEOUT_SECONDS=1800
# review run 软超时时间，单位秒。
REVIEW_RUN_SOFT_TIMEOUT_SECONDS=900
# worker 轮询间隔，单位秒。
WORKER_POLL_INTERVAL_SECONDS=5
# worker 单轮任务锁有效期，单位秒；超时后其他 worker 可接手。
WORKER_LOCK_SECONDS=300
# 失败 review run 的最大重试次数。
RETRY_MAX_ATTEMPTS=2
# 首次重试延迟，单位秒。
RETRY_INITIAL_DELAY_SECONDS=60
