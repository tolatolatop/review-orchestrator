# 应用运行环境：local / staging / production。
APP_ENV=local
# 日志级别：DEBUG / INFO / WARNING / ERROR。
LOG_LEVEL=INFO
# 本地或容器内监听地址。
HOST=0.0.0.0
# 本地或容器内监听端口。
PORT=8000
# self-host 模式下 FastAPI 的本机直连端口；仅绑定 127.0.0.1，不校验 Nginx token。
REVIEW_LOCAL_PORT=18000
# Nginx 反向代理对外端口；self-host 模式下公网只应暴露这个端口。
REVIEW_PROXY_PORT=18080
# 是否启用 Nginx 反向代理 token 校验；设为 false 后所有功能均允许无 token 访问。
REVIEW_PROXY_TOKEN_ENABLED=true
# Nginx 反向代理访问 token；启用校验时必须设置，生产环境必须使用强随机值。
REVIEW_PROXY_TOKEN=

# 数据库连接地址；本地默认使用 SQLite，测试/生产建议使用 PostgreSQL。
DATABASE_URL=sqlite+aiosqlite:///./review_orchestrator.db
# docker-compose.self_host.yaml 使用的 PostgreSQL 数据库名。
POSTGRES_DB=review_orchestrator
# docker-compose.self_host.yaml 使用的 PostgreSQL 用户名。
POSTGRES_USER=review
# docker-compose.self_host.yaml 使用的 PostgreSQL 密码；生产环境必须改为强密码。
POSTGRES_PASSWORD=review
# GitHub webhook secret；生产环境必须配置，留空时会跳过签名校验，仅适合本地开发。
GITHUB_WEBHOOK_SECRET=
# GitHub App ID；App 模式下必须与 GITHUB_PRIVATE_KEY_PATH 同时填写。
GITHUB_APP_ID=
# GitHub App 私钥文件路径；self-host Compose 推荐 /run/secrets/github-app.pem。
GITHUB_PRIVATE_KEY_PATH=
# 可选的固定 Installation ID；留空时按仓库自动查询，支持多个 Installation。
GITHUB_INSTALLATION_ID=
# GitHub API 地址；GitHub Enterprise 可替换为企业实例 API 地址。
GITHUB_API_BASE_URL=https://api.github.com
# 旧版静态 token 回退；配置 App ID + 私钥后无需填写，服务会自动签发和刷新 Installation Token。
GITHUB_INSTALLATION_TOKEN=
# Review bot 登录名；GitHub App 通常为 <app-slug>[bot]。
REVIEW_BOT_LOGIN=review-agent

# GitLab webhook shared token；生产环境必须配置，留空时会跳过 token 校验。
GITLAB_WEBHOOK_SECRET=
# GitLab API 地址；自托管 GitLab 可替换为实例 API 地址。
GITLAB_API_BASE_URL=https://gitlab.com/api/v4
# GitLab bot/project/group token，用于 MR changes 查询和 summary note 发布。
GITLAB_API_TOKEN=
# 平台权限诊断请求超时秒数。
PLATFORM_DIAGNOSTICS_TIMEOUT_SECONDS=10
# GitHub/GitLab API 请求超时秒数。
PROVIDER_API_TIMEOUT_SECONDS=30

# Review Orchestrator 调用 pi-agent runtime 的地址。
PI_AGENT_BASE_URL=http://localhost:3210
# pi-agent runtime 本机诊断端口；仅监听 127.0.0.1。
PI_AGENT_RUNTIME_PORT=3210
# Orchestrator 与 runtime 之间的 Bearer token；生产环境必须使用强随机值。
PI_AGENT_RUNTIME_TOKEN=
# Runtime 部署级 LLM provider、模型和推理强度；Task 请求不能覆盖。
PI_AGENT_PROVIDER=openai
PI_AGENT_MODEL=gpt-5.4
PI_AGENT_THINKING_LEVEL=high
# OpenAI 兼容网关地址；使用 pi 内置 provider 地址时留空。
PI_AGENT_MODEL_BASE_URL=
# 非标准/custom provider 的通用 API key；内置 provider 也可使用其标准环境变量。
PI_AGENT_LLM_API_KEY=
# 示例：OpenAI 内置 provider 使用此变量；不要提交真实 key。
OPENAI_API_KEY=
# 示例：Anthropic 内置 provider 使用此变量；不要提交真实 key。
ANTHROPIC_API_KEY=
# 其他常用 pi 内置 provider。
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=
# Agent 与 Repository Skill 默认选择；Task Type 在 Runtime 中映射命名 preset。
PI_AGENT_REVIEW_AGENT=code-review
PI_AGENT_REVIEW_SKILL=code-review
# @bot 消息指令使用的可写 Agent 和 Repository Skill。
AGENT_COMMAND_ENABLED=true
AGENT_COMMAND_AGENT=pr-assistant
AGENT_COMMAND_SKILL=pr-assistant
# 消息任务软/硬超时；软超时刷新占位评论，硬超时取消 runtime。
AGENT_TASK_SOFT_TIMEOUT_SECONDS=120
AGENT_TASK_TIMEOUT_SECONDS=600
# 同一 PR 最近成功问答的上下文边界。
AGENT_TASK_MAX_HISTORY_TURNS=6
AGENT_TASK_MAX_HISTORY_CHARS=24000
# 允许触发消息指令的 GitHub author_association。
AGENT_TASK_ALLOWED_ASSOCIATIONS=OWNER,MEMBER,COLLABORATOR
# 去除 @bot 后的最大指令长度。
AGENT_TASK_MAX_COMMAND_CHARS=8000
# 自定义 skills 和 models.json 所在的宿主机目录。
PI_AGENT_SKILLS_PATH=./pi-agent-runtime/skills
PI_AGENT_CONFIG_PATH=./pi-agent-runtime/config
# 可克隆的预构建 Task 环境；npm Skill 安装在每 Task overlay 中。
PI_AGENT_ENVIRONMENT_TEMPLATE_PATH=./pi-agent-runtime/environment-template
# Orchestrator 调用 runtime 的 HTTP 超时秒数。
PI_AGENT_TIMEOUT_SECONDS=30

# PR workspace 存储根目录；生产环境建议挂载到持久化磁盘。
WORKSPACE_ROOT=./.workspaces
# Git bare mirror 缓存目录，用于加速重复 checkout。
GIT_CACHE_ROOT=./.git-cache
# review run 硬超时时间，单位秒。
REVIEW_RUN_TIMEOUT_SECONDS=1800
# review run 软超时时间，单位秒。
REVIEW_RUN_SOFT_TIMEOUT_SECONDS=900
# worker 轮询间隔，单位秒。
WORKER_POLL_INTERVAL_SECONDS=5
# worker 单轮任务锁有效期，单位秒；超时后其他 worker 可接手。
WORKER_LOCK_SECONDS=300
# Scheduler 优先级 aging、扫描范围及各维度默认计数容量。
TASK_PRIORITY_AGING_SECONDS=300
TASK_SCHEDULER_SCAN_LIMIT=64
TASK_RESOURCE_CAPACITIES=user=4,repository=4,pr=1,pr_head=1,comment=1,model=4,concurrency=1
# 失败 review run 的最大重试次数。
RETRY_MAX_ATTEMPTS=2
# 首次重试延迟，单位秒。
RETRY_INITIAL_DELAY_SECONDS=60
